# App-side environment. Copy to .env for local Node iteration; for Databricks
# Apps deploy these are sourced from apps/bdc-sharing/app.yaml.

# Workspace path of the BDC publish notebook. Leave unset to fall back to the
# bundle's deployed copy at <bundle-files>/notebooks/bdc_publish.py.
BDC_NOTEBOOK_PATH=

# Same for the unpublish notebook.
BDC_UNPUBLISH_NOTEBOOK_PATH=

# 3-part Delta table for the activity log. Leave empty to let the in-app
# wizard provision a destination interactively. If set, the wizard is
# disabled and this value is the single source of truth.
BDC_ACTIVITY_TABLE=

# UC group whose members see the "Show all users" toggle on the Activity tab.
BDC_ACTIVITY_ADMIN_GROUP=admins
